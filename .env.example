# --- Auth.js / NextAuth v5 ---
# Generate with: npx auth secret
AUTH_SECRET=

# Google OAuth client (Google Cloud Console -> APIs & Services -> Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Required when not on localhost (Vercel sets this implicitly, but it is safe
# to leave true everywhere). Auth.js v5 trusts Vercel hosts automatically.
AUTH_TRUST_HOST=true

# --- Database (Neon Postgres) ---
# Pooled connection string used at runtime
DATABASE_URL=
# Direct (non-pooled) connection string used by Prisma migrations
DIRECT_URL=

# --- OpenAI (GPT-4o-mini) ---
# Optional: without it, task input is stored as-is.
OPENAI_API_KEY=
